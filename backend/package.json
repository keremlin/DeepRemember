{
  "name": "DeepRemember-Backend",
  "version": "0.0.1",
  "description": "DeepRemember-Backend a express.js server for the DeepRemember-App",
  "main": "server.js",
  "scripts": {
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "build": "node build-production.js",
    "start": "node server.js",
    "setup-google-oauth": "node filesystem/setup-oauth.js",
    "setup-google-oauth-alt": "node filesystem/setup-oauth-alternative.js",
    "re-auth-google": "node filesystem/re-auth.cjs"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": ["./tests/setup.js"],
    "testMatch": ["**/tests/**/*.test.js"],
    "testTimeout": 15000
  },
  "keywords": [
    "express",
    "server",
    "DeepRemember",
    "App"
  ],
  "author": "Arash Yeganehrad",
  "license": "MIT",
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.20.0",
    "@google-cloud/text-to-speech": "^6.4.0",
    "@supabase/supabase-js": "^2.75.1",
    "better-sqlite3": "^12.2.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "googleapis": "^164.1.0",
    "groq-sdk": "^0.6.0",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "ts-fsrs": "^5.2.2"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "jest": "^30.2.0",
    "supertest": "^7.2.2"
  }
}
